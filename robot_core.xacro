<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="670610792_lab52">
    <xacro:include filename="inertial_macros.xacro" />

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>
    <material name="purple">
        <color rgba="0.5 0 0.5 1"/>
    </material>
    <material name="yellow">
        <color rgba="1 1 0 1"/>
    </material>

    <material name="cyan">
        <color rgba="0 1 1 1"/>
    </material>
    

    <link name="base_link">

    </link>
    
    <!-- BASE_FOOTPRINT LINK -->
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- Chassis รถ -->
    <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0"/> 
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0.075" rpy="0 0 0"/>
            <geometry>
                <box size="0.5 0.5 0.175"/>
            </geometry>
            <material name="purple"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.075" rpy="0 0 0"/>
            <geometry>
                <box size="0.5 0.5 0.175"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="100.0" x="0.5" y="0.5" z="0.175">
                <origin xyz="0.0 0.0 0.075" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="chassis">
        <material>Gazebo/Black</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

    <!-- ล้อซ้ายหน้า -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.15 0.27 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>    
    
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.04" radius="0.05" />
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="2.0" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Red</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>

    <!-- ล้อขวาหน้า -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.15 -0.27 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.04" radius="0.05" />
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="2.0" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy ="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="right_wheel">
        <material>Gazebo/Green</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>

    <!-- ล้อซ้ายหลัง -->
    <joint name="rear_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rear_left_wheel"/>
        <origin xyz="-0.15 0.27 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rear_left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.04" radius="0.05" />
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/> 
            <geometry>
                <cylinder length="0.04" radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="2.0" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Blue</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>
    
    <!-- ล้อขวาหลัง -->
    <joint name="rear_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rear_right_wheel"/>
        <origin xyz="-0.15 -0.27 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="rear_right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.04" radius="0.05" />
            </geometry>
            <material name="cyan"/>
        </visual>
        <collision>
             <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="2.0" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy ="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="rear_right_wheel">
        <material>Gazebo/Yellow</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>


    <!-- caster wheel -->
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel"/>
        <origin xyz="0.2 0 0.015" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.05" />
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    
    <gazebo reference="caster_wheel">
        <material>Gazebo/Orange</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

    <joint name="casterback_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="casterback_wheel"/>
        <origin xyz="-0.2 0 0.015" rpy="0 0 0"/>
    </joint>

    <link name="casterback_wheel">
        <visual>
            <geometry>
                <sphere radius="0.05" />
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    
    <gazebo reference="casterback_wheel">
        <material>Gazebo/Purple</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>


    <!-- Arm parts -->
   <joint name="arm_base_joint" type="fixed">
        <parent link="chassis"/>
        <child link="arm_base"/>
        <origin xyz="0.0 0 0.1625" rpy="0 0 0"/>
    </joint>

    <link name="arm_base">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.15 0.15 0.1"/></geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.15 0.15 0.1"/></geometry>
        </collision>
        <xacro:inertial_box mass="20.0" x="0.15" y="0.15" z="0.1">
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="shoulder_joint" type="revolute">
        <parent link="arm_base"/>
        <child link="boom_link"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/> <axis xyz="0 -1 0"/> 
        
        <limit lower="-0.785" upper="1.57" effort="100000.0" velocity="0.5"/>
        
        <dynamics damping="1000.0" friction="1000.0"/>
    </joint>

    <link name="boom_link">
        <visual>
            <origin xyz="0.25 0 0" rpy="0 0 0"/>
            <geometry><box size="0.5 0.1 0.05"/></geometry> 
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0.25 0 0" rpy="0 0 0"/>
            <geometry><box size="0.5 0.1 0.05"/></geometry>
        </collision>
        <xacro:inertial_box mass="3.0" x="0.5" y="0.1" z="0.05">
            <origin xyz="0.25 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    

    

    <joint name="wrist_joint" type="revolute">
        <parent link="boom_link"/>
        <child link="wrist_link"/>
        <origin xyz="0.45 0 0.025" rpy="0 0 0"/> 
        <axis xyz="0 -1 0"/>
        <limit lower="-1.5" upper="1.5" effort="50000.0" velocity="0.5"/>
        <dynamics damping="100.0" friction="100.0"/>
    </joint>

    <link name="wrist_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry><cylinder radius="0.04" length="0.1"/></geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry><cylinder radius="0.04" length="0.1"/></geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.5" radius="0.04" length="0.1">
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <joint name="gripper_base_joint" type="fixed">
        <parent link="wrist_link"/>
        <child link="gripper_base"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/> 
    </joint>

    <link name="gripper_base">
        <visual>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <geometry><box size="0.1 0.65 0.05"/></geometry>
            <material name="purple"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <geometry><box size="0.1 0.65 0.05"/></geometry>
        </collision>
        <xacro:inertial_box mass="1.0" x="0.1" y="0.65" z="0.05">
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="left_finger_joint" type="prismatic">
        <parent link="gripper_base"/>
        <child link="left_finger"/>
        <origin xyz="0.05 0.30 0.025" rpy="0 0 0"/> 
        <axis xyz="0 -1 0"/>
        
        <limit lower="0.0" upper="0.265" effort="1000.0" velocity="0.1"/> 
        
        <dynamics damping="100.0" friction="100.0"/>
    </joint>

    <link name="left_finger">
        <visual>
            <origin xyz="0.2 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.05 0.05"/></geometry>
            <material name="red"/>
        </visual>
        <collision name="left_finger_collision"> <origin xyz="0.2 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.05 0.05"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.4" y="0.05" z="0.05">
            <origin xyz="0.2 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="right_finger_joint" type="prismatic">
        <parent link="gripper_base"/>
        <child link="right_finger"/>
        <origin xyz="0.05 -0.30 0.025" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        
        <limit lower="0.0" upper="0.265" effort="1000.0" velocity="0.1"/>
        
        <dynamics damping="100.0" friction="100.0"/>
    </joint>

    <link name="right_finger">
        <visual>
            <origin xyz="0.2 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.05 0.05"/></geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0.2 0 0" rpy="0 0 0"/>
            <geometry><box size="0.4 0.05 0.05"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.4" y="0.05" z="0.05">
            <origin xyz="0.2 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    
    <gazebo reference="left_finger">
        <material>Gazebo/Red</material>
        <mu1>100000.0</mu1> <mu2>100000.0</mu2>
        <kp>100000.0</kp> <kd>100.0</kd>
        <sensor name="left_finger_contact" type="contact">
            <contact>
                <collision>left_finger_collision</collision>
            </contact>
        </sensor>
    </gazebo>
    <gazebo reference="right_finger">
        <material>Gazebo/Red</material>
        <mu1>100000.0</mu1> <mu2>100000.0</mu2>
        <kp>100000.0</kp> <kd>100.0</kd>
        <sensor name="right_finger_contact" type="contact">
            <always_on>true</always_on>
            <contact>
                <collision>right_finger_collision</collision>
            </contact>
        </sensor>
        
    </gazebo>


    <!-- Plugin -->
    <gazebo>
        <plugin name="gazebo_grasp_fix" filename="libgazebo_grasp_fix.so">
            <arm>
                <arm_name>my_gripper</arm_name>
                
                <palm_link>wrist_link</palm_link>
                
                <gripper_link>left_finger</gripper_link>
                <gripper_link>right_finger</gripper_link>
            </arm>
            
            <forces_angle_tolerance>100</forces_angle_tolerance>
            <update_rate>10</update_rate>
            <grip_count_threshold>2</grip_count_threshold>
            <max_grip_count>8</max_grip_count>
            <release_tolerance>0.01</release_tolerance>
            <disable_collisions_on_attach>false</disable_collisions_on_attach>
            <contact_topic>__default_topic__</contact_topic>
        </plugin>
    </gazebo>
</robot>